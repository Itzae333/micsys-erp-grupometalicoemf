// GrupoMetalicoEMF ERP — Schema Prisma v2.0.0
// Arquitectura: datos operativos (inventario, clientes, ventas, pedidos, compras)
// por UBICACION. Datos estructurales (usuarios, proveedores, RH) por EMPRESA.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// EMPRESAS
// ─────────────────────────────────────────────────────────────

model Empresa {
  id           String   @id @default(cuid())
  nombre       String
  razon_social String
  rfc          String
  logo_url     String?
  activa       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Datos estructurales — nivel empresa
  ubicaciones           Ubicacion[]
  usuarios              Usuario[]
  config_columnas       ConfigColumnasUbicacion[]
  proveedores           Proveedor[]
  empleados             Empleado[]
  areas                 Area[]
  registros_asistencia  RegistroAsistencia[]
  ordenes_produccion    OrdenProduccion[]
  solicitudes_edicion   SolicitudEdicionNota[]
  evidencias_nota       EvidenciaNota[]
  legacy_ventas         LegacyVenta[]
  remisiones_origen     Remision[] @relation("RemisionOrigenEmpresa")
  remisiones_destino    Remision[] @relation("RemisionDestinoEmpresa")

  @@map("empresas")
}

// ─────────────────────────────────────────────────────────────
// UBICACIONES
// ─────────────────────────────────────────────────────────────

model Ubicacion {
  id         String        @id @default(cuid())
  empresa_id String
  nombre     String
  tipo       TipoUbicacion
  activa     Boolean       @default(true)

  // Datos fiscales (se imprimen en tickets y PDFs)
  razon_social   String?
  rfc            String?
  regimen_fiscal String?
  calle          String?
  num_ext        String?
  num_int        String?
  colonia        String?
  municipio      String?
  estado         String?
  cp             String?
  telefono       String?
  logo_url       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa         Empresa                   @relation(fields: [empresa_id], references: [id])
  usuarios        UsuarioUbicacion[]
  config_columnas ConfigColumnasUbicacion[]

  // Datos operativos — nivel ubicación
  articulos              Articulo[]
  clientes               Cliente[]
  notas_venta            NotaVenta[]
  movimientos_cuenta     MovimientoCuenta[]
  movimientos_inventario MovimientoInventario[]
  ordenes_compra         OrdenCompra[]
  movimientos_proveedor  MovimientoCuentaProveedor[]
  pedidos                Pedido[]
  anticipos_pedido       AnticiposPedido[]
  remisiones_origen      Remision[] @relation("RemisionOrigenUbicacion")
  remisiones_destino     Remision[] @relation("RemisionDestinoUbicacion")

  @@map("ubicaciones")
}

enum TipoUbicacion {
  MATRIZ
  FABRICA
  PUNTO_VENTA
}

// ─────────────────────────────────────────────────────────────
// USUARIOS Y AUTH
// ─────────────────────────────────────────────────────────────

model Usuario {
  id             String     @id @default(cuid())
  empresa_id     String
  nombre         String
  apellidos      String
  email          String     @unique
  password_hash  String
  rol            RolUsuario
  activo         Boolean    @default(true)
  ultimo_acceso  DateTime?
  allowed_ips    String[]   @default([])
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  empresa                Empresa              @relation(fields: [empresa_id], references: [id])
  ubicaciones            UsuarioUbicacion[]
  refresh_tokens         RefreshToken[]
  notas_venta            NotaVenta[]
  movimientos_cuenta     MovimientoCuenta[]
  movimientos_inventario MovimientoInventario[]
  ordenes_compra         OrdenCompra[]
  movimientos_proveedor  MovimientoCuentaProveedor[]
  registros_asistencia   RegistroAsistencia[]
  ordenes_produccion     OrdenProduccion[]
  solicitudes_enviadas   SolicitudEdicionNota[] @relation("SolicitudSolicitante")
  solicitudes_aprobadas  SolicitudEdicionNota[] @relation("SolicitudAprobador")
  evidencias_subidas     EvidenciaNota[]
  pedidos_creados        Pedido[]
  anticipos_pedido       AnticiposPedido[]
  evidencias_pedido      EvidenciaPedido[]
  empleado               Empleado?
  remisiones_creadas     Remision[] @relation("RemisionCreador")
  remisiones_enviadas    Remision[] @relation("RemisionEnviador")
  remisiones_recibidas   Remision[] @relation("RemisionReceptor")

  @@map("usuarios")
}

model UsuarioUbicacion {
  id           String   @id @default(cuid())
  usuario_id   String
  ubicacion_id String
  created_at   DateTime @default(now())

  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])

  @@unique([usuario_id, ubicacion_id])
  @@map("usuario_ubicaciones")
}

enum RolUsuario {
  SUPER_USUARIO
  ADMIN
  ENCARGADO
  VENDEDOR
  ALMACENISTA
  JEFE_MANUFACTURA
  JEFE_RH
}

model RefreshToken {
  id         String   @id @default(cuid())
  usuario_id String
  token      String   @unique
  expires_at DateTime
  revocado   Boolean  @default(false)
  created_at DateTime @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// CONFIGURACIÓN DE COLUMNAS POR UBICACIÓN
// Define qué columnas de precio/existencia/descripción están
// activas y cómo se llaman. Máximos inamovibles:
//   10 precios, 5 existencias, 5 descripciones
// ─────────────────────────────────────────────────────────────

model ConfigColumnasUbicacion {
  id           String      @id @default(cuid())
  empresa_id   String
  ubicacion_id String
  tipo         TipoColumna
  numero       Int
  label        String
  activa       Boolean     @default(true)
  orden        Int
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  empresa   Empresa   @relation(fields: [empresa_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])

  @@unique([empresa_id, ubicacion_id, tipo, numero])
  @@map("config_columnas_ubicacion")
}

enum TipoColumna {
  PRECIO
  EXISTENCIA
  DESCRIPCION
}

// ─────────────────────────────────────────────────────────────
// PROVEEDORES — nivel EMPRESA (compartido entre sucursales)
// ─────────────────────────────────────────────────────────────

model Proveedor {
  id              String   @id @default(cuid())
  empresa_id      String
  nombre          String
  razon_social    String?
  rfc             String?
  telefono        String?
  email           String?
  direccion       String?
  activo          Boolean  @default(true)
  saldo_pendiente Decimal  @default(0) @db.Decimal(12, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  empresa                Empresa                    @relation(fields: [empresa_id], references: [id])
  articulos              Articulo[]
  movimientos_inventario MovimientoInventario[]
  ordenes_compra         OrdenCompra[]
  movimientos_proveedor  MovimientoCuentaProveedor[]

  @@map("proveedores")
}

// ─────────────────────────────────────────────────────────────
// ARTÍCULOS — nivel UBICACIÓN
// Cada sucursal tiene su propio catálogo independiente.
// precio_1..10    → slots controlados por ConfigColumnasUbicacion PRECIO
// existencia_1..5 → sub-almacenes dentro de la ubicación
// ─────────────────────────────────────────────────────────────

model Articulo {
  id           String  @id @default(cuid())
  ubicacion_id String
  clave        String
  activo       Boolean @default(true)
  imagen_url   String?
  proveedor_id String?

  precio_1  Decimal? @db.Decimal(12, 2)
  precio_2  Decimal? @db.Decimal(12, 2)
  precio_3  Decimal? @db.Decimal(12, 2)
  precio_4  Decimal? @db.Decimal(12, 2)
  precio_5  Decimal? @db.Decimal(12, 2)
  precio_6  Decimal? @db.Decimal(12, 2)
  precio_7  Decimal? @db.Decimal(12, 2)
  precio_8  Decimal? @db.Decimal(12, 2)
  precio_9  Decimal? @db.Decimal(12, 2)
  precio_10 Decimal? @db.Decimal(12, 2)

  existencia_1 Decimal? @db.Decimal(12, 3)
  existencia_2 Decimal? @db.Decimal(12, 3)
  existencia_3 Decimal? @db.Decimal(12, 3)
  existencia_4 Decimal? @db.Decimal(12, 3)
  existencia_5 Decimal? @db.Decimal(12, 3)

  descripcion_1 String?
  descripcion_2 String?
  descripcion_3 String?
  descripcion_4 String?
  descripcion_5 String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  ubicacion              Ubicacion            @relation(fields: [ubicacion_id], references: [id])
  proveedor              Proveedor?           @relation(fields: [proveedor_id], references: [id])
  lineas_venta           NotaVentaLinea[]
  lineas_pedido          PedidoLinea[]
  movimientos_inventario MovimientoInventario[]
  lineas_compra          OrdenCompraLinea[]
  ordenes_produccion     OrdenProduccion[]
  remision_lineas        RemisionLinea[]

  @@unique([ubicacion_id, clave])
  @@map("articulos")
}

// ─────────────────────────────────────────────────────────────
// VENTAS — nivel UBICACIÓN
// ─────────────────────────────────────────────────────────────

model Cliente {
  id           String  @id @default(cuid())
  ubicacion_id String
  nombre       String
  apellidos    String?
  razon_social String?
  rfc          String?
  telefono     String?
  email        String?
  direccion    String?
  activo       Boolean @default(true)

  precio_num      Int?
  limite_credito  Decimal @default(0) @db.Decimal(12, 2)
  saldo_pendiente Decimal @default(0) @db.Decimal(12, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  ubicacion   Ubicacion          @relation(fields: [ubicacion_id], references: [id])
  notas       NotaVenta[]
  pedidos     Pedido[]
  movimientos MovimientoCuenta[]

  @@map("clientes")
}

enum EstatusNota {
  COTIZACION
  ABIERTA
  PENDIENTE
  PAGADA
  CREDITO
  CANCELADA
  REABIERTA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  DEPOSITO
}

model NotaVenta {
  id           String      @id @default(cuid())
  folio        Int
  ubicacion_id String
  usuario_id   String
  cliente_id   String?

  estatus   EstatusNota @default(ABIERTA)
  subtotal  Decimal     @db.Decimal(12, 2)
  descuento Decimal     @default(0) @db.Decimal(12, 2)
  total     Decimal     @db.Decimal(12, 2)

  es_credito        Boolean   @default(false)
  fecha_vencimiento DateTime?
  observaciones     String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  cerrada_at DateTime?

  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])
  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  cliente   Cliente?  @relation(fields: [cliente_id], references: [id])

  lineas              NotaVentaLinea[]
  pagos               Pago[]
  movimientos         MovimientoCuenta[]
  solicitudes_edicion SolicitudEdicionNota[]
  evidencias          EvidenciaNota[]
  pedido_origen       Pedido?

  @@unique([ubicacion_id, folio])
  @@map("notas_venta")
}

model NotaVentaLinea {
  id          String @id @default(cuid())
  nota_id     String
  articulo_id String
  clave       String

  cantidad        Decimal @db.Decimal(12, 3)
  precio_unitario Decimal @db.Decimal(12, 2)
  descuento       Decimal @default(0) @db.Decimal(5, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  created_at DateTime @default(now())

  nota     NotaVenta @relation(fields: [nota_id], references: [id])
  articulo Articulo  @relation(fields: [articulo_id], references: [id])

  @@map("nota_venta_lineas")
}

model Pago {
  id         String     @id @default(cuid())
  nota_id    String
  metodo     MetodoPago
  monto      Decimal    @db.Decimal(12, 2)
  referencia String?
  created_at DateTime   @default(now())

  nota NotaVenta @relation(fields: [nota_id], references: [id])

  @@map("pagos")
}

// ─────────────────────────────────────────────────────────────
// CRÉDITO Y CUENTAS — nivel UBICACIÓN
// ─────────────────────────────────────────────────────────────

enum TipoMovimientoCuenta {
  CARGO
  ABONO
  AJUSTE
}

model MovimientoCuenta {
  id            String               @id @default(cuid())
  ubicacion_id  String
  cliente_id    String
  tipo          TipoMovimientoCuenta
  monto         Decimal              @db.Decimal(12, 2)
  saldo_antes   Decimal              @db.Decimal(12, 2)
  saldo_despues Decimal              @db.Decimal(12, 2)
  concepto      String
  nota_id       String?
  usuario_id    String
  created_at    DateTime             @default(now())

  ubicacion Ubicacion  @relation(fields: [ubicacion_id], references: [id])
  cliente   Cliente    @relation(fields: [cliente_id], references: [id])
  nota      NotaVenta? @relation(fields: [nota_id], references: [id])
  usuario   Usuario    @relation(fields: [usuario_id], references: [id])

  @@index([ubicacion_id, cliente_id, created_at])
  @@map("movimientos_cuenta")
}

// ─────────────────────────────────────────────────────────────
// MOVIMIENTOS DE INVENTARIO — nivel UBICACIÓN
// existencia_num 1..5 = sub-almacén dentro de la ubicación
// ─────────────────────────────────────────────────────────────

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  TRANSFERENCIA_OUT
  TRANSFERENCIA_IN
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

model MovimientoInventario {
  id               String                   @id @default(cuid())
  ubicacion_id     String
  articulo_id      String
  tipo             TipoMovimientoInventario
  existencia_num   Int
  cantidad         Decimal                  @db.Decimal(12, 3)
  cantidad_antes   Decimal                  @db.Decimal(12, 3)
  cantidad_despues Decimal                  @db.Decimal(12, 3)
  concepto         String
  proveedor_id     String?
  referencia_id    String?
  usuario_id       String
  created_at       DateTime                 @default(now())

  ubicacion Ubicacion  @relation(fields: [ubicacion_id], references: [id])
  articulo  Articulo   @relation(fields: [articulo_id], references: [id])
  proveedor Proveedor? @relation(fields: [proveedor_id], references: [id])
  usuario   Usuario    @relation(fields: [usuario_id], references: [id])

  @@index([ubicacion_id, articulo_id, created_at])
  @@index([ubicacion_id, created_at])
  @@map("movimientos_inventario")
}

// ─────────────────────────────────────────────────────────────
// REMISIONES — transferencias entre ubicaciones
// ─────────────────────────────────────────────────────────────

enum EstatusRemision {
  BORRADOR
  EN_TRANSITO
  RECIBIDA_COMPLETA
  RECIBIDA_PARCIAL
  CANCELADA
}

model Remision {
  id                 String          @id @default(cuid())
  folio              String          @unique
  empresa_origen_id  String
  ub_origen_id       String
  empresa_destino_id String
  ub_destino_id      String
  estatus            EstatusRemision @default(BORRADOR)
  concepto           String?
  notas              String?
  creado_por_id      String
  enviado_por_id     String?
  recibido_por_id    String?
  fecha_envio        DateTime?
  fecha_recepcion    DateTime?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  empresa_origen  Empresa   @relation("RemisionOrigenEmpresa",    fields: [empresa_origen_id],  references: [id])
  ub_origen       Ubicacion @relation("RemisionOrigenUbicacion",  fields: [ub_origen_id],       references: [id])
  empresa_destino Empresa   @relation("RemisionDestinoEmpresa",   fields: [empresa_destino_id], references: [id])
  ub_destino      Ubicacion @relation("RemisionDestinoUbicacion", fields: [ub_destino_id],      references: [id])
  creado_por      Usuario   @relation("RemisionCreador",          fields: [creado_por_id],      references: [id])
  enviado_por     Usuario?  @relation("RemisionEnviador",         fields: [enviado_por_id],     references: [id])
  recibido_por    Usuario?  @relation("RemisionReceptor",         fields: [recibido_por_id],    references: [id])

  lineas RemisionLinea[]

  @@index([ub_origen_id, estatus, created_at])
  @@index([ub_destino_id, estatus, created_at])
  @@map("remisiones")
}

model RemisionLinea {
  id                String   @id @default(cuid())
  remision_id       String
  articulo_id       String
  articulo_clave    String
  slot_origen       Int      @default(1)
  slot_destino      Int      @default(1)
  cantidad_enviada  Decimal  @db.Decimal(12, 3)
  cantidad_recibida Decimal? @db.Decimal(12, 3)
  notas             String?

  remision Remision @relation(fields: [remision_id], references: [id], onDelete: Cascade)
  articulo Articulo @relation(fields: [articulo_id], references: [id])

  @@map("remision_lineas")
}

// ─────────────────────────────────────────────────────────────
// COMPRAS Y CUENTAS POR PAGAR — nivel UBICACIÓN
// ─────────────────────────────────────────────────────────────

enum EstatusOrdenCompra {
  BORRADOR
  APROBADA
  RECIBIDA_PARCIAL
  RECIBIDA
  CANCELADA
}

enum TipoMovimientoProveedor {
  CARGO
  ABONO
  AJUSTE
}

model OrdenCompra {
  id            String             @id @default(cuid())
  folio         Int
  ubicacion_id  String
  proveedor_id  String
  estatus       EstatusOrdenCompra @default(BORRADOR)
  subtotal      Decimal            @db.Decimal(12, 2)
  total         Decimal            @db.Decimal(12, 2)
  observaciones String?
  usuario_id    String
  aprobada_at   DateTime?
  recibida_at   DateTime?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  ubicacion Ubicacion  @relation(fields: [ubicacion_id], references: [id])
  proveedor Proveedor  @relation(fields: [proveedor_id], references: [id])
  usuario   Usuario    @relation(fields: [usuario_id], references: [id])

  lineas                OrdenCompraLinea[]
  movimientos_proveedor MovimientoCuentaProveedor[]

  @@unique([ubicacion_id, folio])
  @@index([ubicacion_id, estatus, created_at])
  @@map("ordenes_compra")
}

model OrdenCompraLinea {
  id                  String   @id @default(cuid())
  orden_id            String
  articulo_id         String
  clave               String
  cantidad_solicitada Decimal  @db.Decimal(12, 3)
  cantidad_recibida   Decimal  @default(0) @db.Decimal(12, 3)
  precio_unitario     Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)
  existencia_num      Int      @default(1)
  created_at          DateTime @default(now())

  orden    OrdenCompra @relation(fields: [orden_id], references: [id])
  articulo Articulo    @relation(fields: [articulo_id], references: [id])

  @@map("ordenes_compra_lineas")
}

model MovimientoCuentaProveedor {
  id            String                  @id @default(cuid())
  ubicacion_id  String
  proveedor_id  String
  tipo          TipoMovimientoProveedor
  monto         Decimal                 @db.Decimal(12, 2)
  saldo_antes   Decimal                 @db.Decimal(12, 2)
  saldo_despues Decimal                 @db.Decimal(12, 2)
  concepto      String
  orden_id      String?
  usuario_id    String
  created_at    DateTime                @default(now())

  ubicacion Ubicacion    @relation(fields: [ubicacion_id], references: [id])
  proveedor Proveedor    @relation(fields: [proveedor_id], references: [id])
  orden     OrdenCompra? @relation(fields: [orden_id], references: [id])
  usuario   Usuario      @relation(fields: [usuario_id], references: [id])

  @@index([ubicacion_id, proveedor_id, created_at])
  @@map("movimientos_cuenta_proveedor")
}

// ─────────────────────────────────────────────────────────────
// RECURSOS HUMANOS — nivel EMPRESA
// ─────────────────────────────────────────────────────────────

enum TipoPago {
  POR_HORA
  POR_PIEZA
}

enum EstatusAsistencia {
  PRESENTE
  AUSENTE
  TARDANZA
  PERMISO
  VACACIONES
}

enum EstatusProduccion {
  ABIERTA
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

model Area {
  id         String   @id @default(cuid())
  empresa_id String
  nombre     String
  tipo_pago  TipoPago @default(POR_HORA)
  activa     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa   Empresa              @relation(fields: [empresa_id], references: [id])
  empleados Empleado[]
  registros RegistroAsistencia[]

  @@unique([empresa_id, nombre])
  @@index([empresa_id, activa])
  @@map("areas")
}

model Empleado {
  id             String   @id @default(cuid())
  empresa_id     String
  usuario_id     String?  @unique
  nombre         String
  apellidos      String
  puesto         String
  area_id        String?
  salario_diario Decimal  @db.Decimal(12, 2)
  telefono       String?
  fecha_ingreso  DateTime @db.Date
  activo         Boolean  @default(true)
  descuento_por_30min  Decimal? @db.Decimal(10, 2)
  minimo_piezas_semana Int?
  sancion_por_pieza    Decimal? @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  empresa     Empresa              @relation(fields: [empresa_id], references: [id])
  area        Area?                @relation(fields: [area_id], references: [id])
  usuario     Usuario?             @relation(fields: [usuario_id], references: [id])
  asistencias RegistroAsistencia[]

  @@index([empresa_id, activo])
  @@map("empleados")
}

model RegistroAsistencia {
  id                String            @id @default(cuid())
  empresa_id        String
  empleado_id       String
  area_id           String?
  fecha             DateTime          @db.Date
  hora_entrada      DateTime?
  hora_salida       DateTime?
  estatus           EstatusAsistencia @default(PRESENTE)
  minutos_tarde     Int?
  piezas_realizadas Int?
  sancion_monto     Decimal?          @db.Decimal(10, 2)
  sancion_concepto  String?
  observaciones     String?
  usuario_id        String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  empresa  Empresa   @relation(fields: [empresa_id], references: [id])
  empleado Empleado  @relation(fields: [empleado_id], references: [id])
  area     Area?     @relation(fields: [area_id], references: [id])
  usuario  Usuario   @relation(fields: [usuario_id], references: [id])

  @@unique([empleado_id, fecha])
  @@index([empresa_id, fecha])
  @@map("registros_asistencia")
}

model OrdenProduccion {
  id                 String            @id @default(cuid())
  folio              Int
  empresa_id         String
  articulo_id        String
  existencia_num     Int               @default(1)
  cantidad_objetivo  Decimal           @db.Decimal(12, 3)
  cantidad_producida Decimal           @default(0) @db.Decimal(12, 3)
  estatus            EstatusProduccion @default(ABIERTA)
  fecha_inicio       DateTime          @db.Date
  fecha_cierre       DateTime?
  observaciones      String?
  usuario_id         String
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  empresa  Empresa  @relation(fields: [empresa_id], references: [id])
  articulo Articulo @relation(fields: [articulo_id], references: [id])
  usuario  Usuario  @relation(fields: [usuario_id], references: [id])

  @@unique([empresa_id, folio])
  @@index([empresa_id, estatus, created_at])
  @@map("ordenes_produccion")
}

// ─────────────────────────────────────────────────────────────
// EDICIÓN CON APROBACIÓN Y EVIDENCIAS — admin nivel EMPRESA
// ─────────────────────────────────────────────────────────────

enum EstatusSolicitudEdicion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoEvidencia {
  TICKET_ORIGINAL
  COMPROBANTE_PAGO
  IMAGEN
  TICKET_REEDITADO
}

model SolicitudEdicionNota {
  id               String                  @id @default(cuid())
  nota_id          String
  empresa_id       String
  solicitante_id   String
  motivo           String
  estatus          EstatusSolicitudEdicion @default(PENDIENTE)
  aprobado_por_id  String?
  comentario_admin String?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt

  nota         NotaVenta @relation(fields: [nota_id], references: [id])
  empresa      Empresa   @relation(fields: [empresa_id], references: [id])
  solicitante  Usuario   @relation("SolicitudSolicitante", fields: [solicitante_id], references: [id])
  aprobado_por Usuario?  @relation("SolicitudAprobador",   fields: [aprobado_por_id], references: [id])

  @@index([empresa_id, estatus, created_at])
  @@map("solicitudes_edicion_nota")
}

model EvidenciaNota {
  id            String        @id @default(cuid())
  nota_id       String
  empresa_id    String
  tipo          TipoEvidencia
  descripcion   String?
  archivo_url   String?
  data_json     Json?
  subido_por_id String
  created_at    DateTime      @default(now())

  nota       NotaVenta @relation(fields: [nota_id], references: [id])
  empresa    Empresa   @relation(fields: [empresa_id], references: [id])
  subido_por Usuario   @relation(fields: [subido_por_id], references: [id])

  @@index([nota_id])
  @@map("evidencias_nota")
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS CON ANTICIPOS — nivel UBICACIÓN
// ─────────────────────────────────────────────────────────────

enum EstatusPedido {
  ABIERTO
  PARCIAL
  LIQUIDADO
  CANCELADO
}

model Pedido {
  id              String        @id @default(cuid())
  folio           Int
  ubicacion_id    String
  usuario_id      String
  cliente_id      String
  estatus         EstatusPedido @default(ABIERTO)
  subtotal        Decimal       @db.Decimal(12, 2)
  descuento       Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  total_anticipos Decimal       @default(0) @db.Decimal(12, 2)
  observaciones   String?
  nota_venta_id   String?       @unique
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  cerrado_at      DateTime?

  ubicacion  Ubicacion  @relation(fields: [ubicacion_id], references: [id])
  usuario    Usuario    @relation(fields: [usuario_id], references: [id])
  cliente    Cliente    @relation(fields: [cliente_id], references: [id])
  nota_venta NotaVenta? @relation(fields: [nota_venta_id], references: [id])

  lineas     PedidoLinea[]
  anticipos  AnticiposPedido[]
  evidencias EvidenciaPedido[]

  @@unique([ubicacion_id, folio])
  @@index([ubicacion_id, estatus, created_at])
  @@map("pedidos")
}

model PedidoLinea {
  id              String   @id @default(cuid())
  pedido_id       String
  articulo_id     String
  clave           String
  descripcion     String?
  cantidad        Decimal  @db.Decimal(12, 3)
  precio_unitario Decimal  @db.Decimal(12, 2)
  descuento       Decimal  @default(0) @db.Decimal(5, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  created_at      DateTime @default(now())

  pedido   Pedido   @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  articulo Articulo @relation(fields: [articulo_id], references: [id])

  @@map("pedido_lineas")
}

model AnticiposPedido {
  id           String     @id @default(cuid())
  pedido_id    String
  ubicacion_id String
  usuario_id   String
  metodo       MetodoPago
  monto        Decimal    @db.Decimal(12, 2)
  referencia   String?
  created_at   DateTime   @default(now())

  pedido    Pedido    @relation(fields: [pedido_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])
  usuario   Usuario   @relation(fields: [usuario_id], references: [id])

  @@index([ubicacion_id, created_at])
  @@map("anticipos_pedido")
}

model EvidenciaPedido {
  id            String        @id @default(cuid())
  pedido_id     String
  tipo          TipoEvidencia
  descripcion   String?
  archivo_url   String?
  data_json     Json?
  subido_por_id String
  created_at    DateTime      @default(now())

  pedido     Pedido  @relation(fields: [pedido_id], references: [id])
  subido_por Usuario @relation(fields: [subido_por_id], references: [id])

  @@index([pedido_id])
  @@map("evidencias_pedido")
}

// ─────────────────────────────────────────────────────────────
// LEGACY — Histórico (solo lectura)
// ─────────────────────────────────────────────────────────────

model LegacyVenta {
  id             String   @id @default(cuid())
  empresa_id     String
  legacy_id      Int
  sucursal       String
  cliente_nombre String?
  nota           String?
  incidencia     String?
  recibido       Decimal? @db.Decimal(12, 2)
  cambio         Decimal? @db.Decimal(12, 2)
  restan         Decimal? @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  estatus        String
  tipo_pago      String
  fecha_hora     DateTime
  created_at     DateTime @default(now())

  empresa Empresa            @relation(fields: [empresa_id], references: [id])
  lineas  LegacyVentaLinea[]

  @@unique([empresa_id, sucursal, legacy_id])
  @@index([empresa_id, fecha_hora])
  @@map("legacy_ventas")
}

model LegacyVentaLinea {
  id            String  @id @default(cuid())
  venta_id      String
  descripcion_1 String?
  descripcion_2 String?
  descripcion_3 String?
  color         String?
  material      String?
  cantidad      Decimal @db.Decimal(12, 3)
  precio_neto   Decimal @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  venta LegacyVenta @relation(fields: [venta_id], references: [id], onDelete: Cascade)

  @@map("legacy_venta_lineas")
}

// ─────────────────────────────────────────────────────────────
// AUDITORÍA
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  empresa_id   String?
  usuario_id   String?
  usuario_name String?
  accion       String
  entidad      String
  entidad_id   String?
  cambios      Json?
  ip           String?
  user_agent   String?
  created_at   DateTime @default(now())

  @@index([empresa_id, created_at(sort: Desc)])
  @@index([entidad, entidad_id])
  @@map("audit_logs")
}
