# ─────────────────────────────────────────────────────────────
# GrupoMetalicoEMF API — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# En Railway configura estas mismas variables desde el dashboard.
# ─────────────────────────────────────────────────────────────

# Base de datos (Railway provee este valor con el plugin PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway?sslmode=require"

# JWT — Genera secretos con: openssl rand -base64 64
JWT_SECRET="CAMBIA_POR_UN_SECRETO_LARGO_Y_ALEATORIO"
JWT_REFRESH_SECRET="OTRO_SECRETO_DIFERENTE_PARA_REFRESH_TOKENS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — URL publica del frontend sin barra al final
# Desarrollo: http://localhost:3000  |  Produccion: https://tu-app.vercel.app
FRONTEND_URL="http://localhost:3000"

# Servidor
PORT=3001
NODE_ENV=development

# Email (Nodemailer) — opcional, para send-email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="GrupoMetalicoEMF <no-reply@grupometalicoemf.com>"
