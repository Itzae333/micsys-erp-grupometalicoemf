// GrupoMetalicoEMF ERP — Schema Prisma v1.0.0
// Fase 1: Fundación — Auth, Empresas, Ubicaciones, Usuarios, ConfigColumnas

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// EMPRESAS
// ─────────────────────────────────────────────────────────────

model Empresa {
  id           String   @id @default(cuid())
  nombre       String
  razon_social String
  rfc          String
  logo_url     String?
  activa       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  ubicaciones              Ubicacion[]
  usuarios                 Usuario[]
  config_columnas          ConfigColumnasUbicacion[]
  proveedores              Proveedor[]
  articulos                Articulo[]
  clientes                 Cliente[]
  notas_venta              NotaVenta[]
  movimientos_cuenta       MovimientoCuenta[]
  movimientos_inventario   MovimientoInventario[]
  ordenes_compra           OrdenCompra[]
  movimientos_proveedor    MovimientoCuentaProveedor[]
  empleados                Empleado[]
  areas                    Area[]
  registros_asistencia     RegistroAsistencia[]
  ordenes_produccion       OrdenProduccion[]
  solicitudes_edicion      SolicitudEdicionNota[]
  evidencias_nota          EvidenciaNota[]
  legacy_ventas            LegacyVenta[]

  @@map("empresas")
}

// ─────────────────────────────────────────────────────────────
// UBICACIONES
// ─────────────────────────────────────────────────────────────

model Ubicacion {
  id         String        @id @default(cuid())
  empresa_id String
  nombre     String
  tipo       TipoUbicacion
  activa     Boolean       @default(true)

  // Datos fiscales (se imprimen en tickets y PDFs)
  razon_social   String?
  rfc            String?
  regimen_fiscal String?
  calle          String?
  num_ext        String?
  num_int        String?
  colonia        String?
  municipio      String?
  estado         String?
  cp             String?
  telefono       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa         Empresa                 @relation(fields: [empresa_id], references: [id])
  usuarios        UsuarioUbicacion[]
  config_columnas ConfigColumnasUbicacion[]
  notas_venta     NotaVenta[]

  @@map("ubicaciones")
}

enum TipoUbicacion {
  MATRIZ
  FABRICA
  PUNTO_VENTA
}

// ─────────────────────────────────────────────────────────────
// USUARIOS Y AUTH
// ─────────────────────────────────────────────────────────────

model Usuario {
  id             String     @id @default(cuid())
  empresa_id     String
  nombre         String
  apellidos      String
  email          String     @unique
  password_hash  String
  rol            RolUsuario
  activo         Boolean    @default(true)
  ultimo_acceso  DateTime?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  empresa                Empresa              @relation(fields: [empresa_id], references: [id])
  ubicaciones            UsuarioUbicacion[]
  refresh_tokens         RefreshToken[]
  notas_venta            NotaVenta[]
  movimientos_cuenta     MovimientoCuenta[]
  movimientos_inventario MovimientoInventario[]
  ordenes_compra         OrdenCompra[]
  movimientos_proveedor  MovimientoCuentaProveedor[]
  registros_asistencia   RegistroAsistencia[]
  ordenes_produccion     OrdenProduccion[]
  solicitudes_enviadas   SolicitudEdicionNota[] @relation("SolicitudSolicitante")
  solicitudes_aprobadas  SolicitudEdicionNota[] @relation("SolicitudAprobador")
  evidencias_subidas     EvidenciaNota[]
  empleado               Empleado?

  @@map("usuarios")
}

// Pivot usuario ↔ ubicación
// Un usuario puede estar asignado a múltiples ubicaciones de su empresa
model UsuarioUbicacion {
  id           String   @id @default(cuid())
  usuario_id   String
  ubicacion_id String
  created_at   DateTime @default(now())

  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])

  @@unique([usuario_id, ubicacion_id])
  @@map("usuario_ubicaciones")
}

enum RolUsuario {
  SUPER_USUARIO
  ADMIN
  ENCARGADO
  VENDEDOR
  ALMACENISTA
  JEFE_MANUFACTURA
  JEFE_RH
}

model RefreshToken {
  id         String   @id @default(cuid())
  usuario_id String
  token      String   @unique
  expires_at DateTime
  revocado   Boolean  @default(false)
  created_at DateTime @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// CONFIGURACIÓN DE COLUMNAS POR UBICACIÓN
// Define qué columnas de precio/existencia/descripción están
// activas en una empresa+ubicación y cómo se llaman en el frontend.
// Es el núcleo del inventario parametrizable.
// MÁXIMOS (inamovibles después de Fase 2):
//   - 10 precios, 5 existencias, 5 descripciones
// ─────────────────────────────────────────────────────────────

model ConfigColumnasUbicacion {
  id           String      @id @default(cuid())
  empresa_id   String
  ubicacion_id String
  tipo         TipoColumna
  numero       Int         // 1..10 para PRECIO; 1..5 para EXISTENCIA y DESCRIPCION
  label        String      // "Mayoreo", "Crédito", "Existencia Planta", etc.
  activa       Boolean     @default(true)
  orden        Int         // posición en la tabla de inventario
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  empresa   Empresa   @relation(fields: [empresa_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])

  @@unique([empresa_id, ubicacion_id, tipo, numero])
  @@map("config_columnas_ubicacion")
}

enum TipoColumna {
  PRECIO
  EXISTENCIA
  DESCRIPCION
}

// ─────────────────────────────────────────────────────────────
// PROVEEDORES
// ─────────────────────────────────────────────────────────────

model Proveedor {
  id           String   @id @default(cuid())
  empresa_id   String
  nombre       String
  razon_social String?
  rfc          String?
  telefono     String?
  email        String?
  direccion    String?
  activo          Boolean  @default(true)
  saldo_pendiente Decimal  @default(0) @db.Decimal(12, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  empresa                Empresa                    @relation(fields: [empresa_id], references: [id])
  articulos              Articulo[]
  movimientos_inventario MovimientoInventario[]
  ordenes_compra         OrdenCompra[]
  movimientos_proveedor  MovimientoCuentaProveedor[]

  @@map("proveedores")
}

// ─────────────────────────────────────────────────────────────
// ARTÍCULOS (INVENTARIO)
// precio_1..10    → slots controlados por ConfigColumnasUbicacion PRECIO
// existencia_1..5 → slots controlados por ConfigColumnasUbicacion EXISTENCIA
// Máximos inamovibles post Fase 2: 10 precios, 5 existencias.
// ─────────────────────────────────────────────────────────────

model Articulo {
  id            String   @id @default(cuid())
  empresa_id    String
  clave         String
  activo        Boolean  @default(true)
  imagen_url    String?
  proveedor_id  String?

  precio_1      Decimal? @db.Decimal(12, 2)
  precio_2      Decimal? @db.Decimal(12, 2)
  precio_3      Decimal? @db.Decimal(12, 2)
  precio_4      Decimal? @db.Decimal(12, 2)
  precio_5      Decimal? @db.Decimal(12, 2)
  precio_6      Decimal? @db.Decimal(12, 2)
  precio_7      Decimal? @db.Decimal(12, 2)
  precio_8      Decimal? @db.Decimal(12, 2)
  precio_9      Decimal? @db.Decimal(12, 2)
  precio_10     Decimal? @db.Decimal(12, 2)

  existencia_1  Decimal? @db.Decimal(12, 3)
  existencia_2  Decimal? @db.Decimal(12, 3)
  existencia_3  Decimal? @db.Decimal(12, 3)
  existencia_4  Decimal? @db.Decimal(12, 3)
  existencia_5  Decimal? @db.Decimal(12, 3)

  descripcion_1 String?
  descripcion_2 String?
  descripcion_3 String?
  descripcion_4 String?
  descripcion_5 String?

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  empresa                Empresa              @relation(fields: [empresa_id], references: [id])
  proveedor              Proveedor?           @relation(fields: [proveedor_id], references: [id])
  lineas_venta           NotaVentaLinea[]
  movimientos_inventario MovimientoInventario[]
  lineas_compra          OrdenCompraLinea[]
  ordenes_produccion     OrdenProduccion[]

  @@unique([empresa_id, clave])
  @@map("articulos")
}

// ─────────────────────────────────────────────────────────────
// FASE 3 — VENTAS
// ─────────────────────────────────────────────────────────────

model Cliente {
  id           String  @id @default(cuid())
  empresa_id   String
  nombre       String
  apellidos    String?
  razon_social String?
  rfc          String?
  telefono     String?
  email        String?
  direccion    String?
  activo       Boolean @default(true)

  precio_num      Int?
  limite_credito  Decimal @default(0) @db.Decimal(12, 2)
  saldo_pendiente Decimal @default(0) @db.Decimal(12, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa      Empresa            @relation(fields: [empresa_id], references: [id])
  notas        NotaVenta[]
  movimientos  MovimientoCuenta[]

  @@map("clientes")
}

enum EstatusNota {
  COTIZACION
  ABIERTA
  PENDIENTE
  PAGADA
  CREDITO
  CANCELADA
  REABIERTA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  DEPOSITO
}

model NotaVenta {
  id           String      @id @default(cuid())
  folio        Int
  empresa_id   String
  ubicacion_id String
  usuario_id   String
  cliente_id   String?

  estatus   EstatusNota @default(ABIERTA)

  subtotal  Decimal @db.Decimal(12, 2)
  descuento Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  es_credito        Boolean   @default(false)
  fecha_vencimiento DateTime?
  observaciones     String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  cerrada_at DateTime?

  empresa   Empresa   @relation(fields: [empresa_id], references: [id])
  ubicacion Ubicacion @relation(fields: [ubicacion_id], references: [id])
  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  cliente   Cliente?  @relation(fields: [cliente_id], references: [id])
  lineas             NotaVentaLinea[]
  pagos              Pago[]
  movimientos        MovimientoCuenta[]
  solicitudes_edicion SolicitudEdicionNota[]
  evidencias         EvidenciaNota[]

  @@unique([empresa_id, folio])
  @@map("notas_venta")
}

model NotaVentaLinea {
  id          String @id @default(cuid())
  nota_id     String
  articulo_id String

  clave         String

  cantidad        Decimal @db.Decimal(12, 3)
  precio_unitario Decimal @db.Decimal(12, 2)
  descuento       Decimal @default(0) @db.Decimal(5, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  created_at DateTime @default(now())

  nota     NotaVenta @relation(fields: [nota_id], references: [id])
  articulo Articulo  @relation(fields: [articulo_id], references: [id])

  @@map("nota_venta_lineas")
}

model Pago {
  id         String     @id @default(cuid())
  nota_id    String
  metodo     MetodoPago
  monto      Decimal    @db.Decimal(12, 2)
  referencia String?
  created_at DateTime   @default(now())

  nota NotaVenta @relation(fields: [nota_id], references: [id])

  @@map("pagos")
}

// ─────────────────────────────────────────────────────────────
// FASE 4 — CRÉDITO Y CUENTAS
// ─────────────────────────────────────────────────────────────

enum TipoMovimientoCuenta {
  CARGO
  ABONO
  AJUSTE
}

model MovimientoCuenta {
  id            String               @id @default(cuid())
  empresa_id    String
  cliente_id    String
  tipo          TipoMovimientoCuenta
  monto         Decimal              @db.Decimal(12, 2)
  saldo_antes   Decimal              @db.Decimal(12, 2)
  saldo_despues Decimal              @db.Decimal(12, 2)
  concepto      String
  nota_id       String?
  usuario_id    String
  created_at    DateTime             @default(now())

  empresa  Empresa    @relation(fields: [empresa_id], references: [id])
  cliente  Cliente    @relation(fields: [cliente_id], references: [id])
  nota     NotaVenta? @relation(fields: [nota_id], references: [id])
  usuario  Usuario    @relation(fields: [usuario_id], references: [id])

  @@index([empresa_id, cliente_id, created_at])
  @@map("movimientos_cuenta")
}

// ─────────────────────────────────────────────────────────────
// FASE 5 — ENTRADAS Y SALIDAS (MOVIMIENTOS DE INVENTARIO)
// existencia_num 1..5 corresponde a existencia_1..existencia_5
// en Articulo. La transferencia crea un par OUT+IN con mismo
// referencia_id para mantener trazabilidad.
// ─────────────────────────────────────────────────────────────

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  TRANSFERENCIA_OUT
  TRANSFERENCIA_IN
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

model MovimientoInventario {
  id               String                   @id @default(cuid())
  empresa_id       String
  articulo_id      String
  tipo             TipoMovimientoInventario
  existencia_num   Int
  cantidad         Decimal                  @db.Decimal(12, 3)
  cantidad_antes   Decimal                  @db.Decimal(12, 3)
  cantidad_despues Decimal                  @db.Decimal(12, 3)
  concepto         String
  proveedor_id     String?
  referencia_id    String?
  usuario_id       String
  created_at       DateTime                 @default(now())

  empresa   Empresa    @relation(fields: [empresa_id], references: [id])
  articulo  Articulo   @relation(fields: [articulo_id], references: [id])
  proveedor Proveedor? @relation(fields: [proveedor_id], references: [id])
  usuario   Usuario    @relation(fields: [usuario_id], references: [id])

  @@index([empresa_id, articulo_id, created_at])
  @@index([empresa_id, created_at])
  @@map("movimientos_inventario")
}

// ─────────────────────────────────────────────────────────────
// FASE 6 — COMPRAS Y CUENTAS POR PAGAR
// Flujo OC: BORRADOR → APROBADA → RECIBIDA_PARCIAL → RECIBIDA
// Recibir OC dispara Entradas F5 y genera CARGO al proveedor.
// ─────────────────────────────────────────────────────────────

enum EstatusOrdenCompra {
  BORRADOR
  APROBADA
  RECIBIDA_PARCIAL
  RECIBIDA
  CANCELADA
}

enum TipoMovimientoProveedor {
  CARGO
  ABONO
  AJUSTE
}

model OrdenCompra {
  id            String             @id @default(cuid())
  folio         Int
  empresa_id    String
  proveedor_id  String
  estatus       EstatusOrdenCompra @default(BORRADOR)
  subtotal      Decimal            @db.Decimal(12, 2)
  total         Decimal            @db.Decimal(12, 2)
  observaciones String?
  usuario_id    String
  aprobada_at   DateTime?
  recibida_at   DateTime?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  empresa    Empresa    @relation(fields: [empresa_id], references: [id])
  proveedor  Proveedor  @relation(fields: [proveedor_id], references: [id])
  usuario    Usuario    @relation(fields: [usuario_id], references: [id])
  lineas     OrdenCompraLinea[]
  movimientos_proveedor MovimientoCuentaProveedor[]

  @@unique([empresa_id, folio])
  @@index([empresa_id, estatus, created_at])
  @@map("ordenes_compra")
}

model OrdenCompraLinea {
  id                  String   @id @default(cuid())
  orden_id            String
  articulo_id         String
  clave               String
  cantidad_solicitada Decimal  @db.Decimal(12, 3)
  cantidad_recibida   Decimal  @default(0) @db.Decimal(12, 3)
  precio_unitario     Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)
  existencia_num      Int      @default(1)
  created_at          DateTime @default(now())

  orden    OrdenCompra @relation(fields: [orden_id], references: [id])
  articulo Articulo    @relation(fields: [articulo_id], references: [id])

  @@map("ordenes_compra_lineas")
}

model MovimientoCuentaProveedor {
  id            String                  @id @default(cuid())
  empresa_id    String
  proveedor_id  String
  tipo          TipoMovimientoProveedor
  monto         Decimal                 @db.Decimal(12, 2)
  saldo_antes   Decimal                 @db.Decimal(12, 2)
  saldo_despues Decimal                 @db.Decimal(12, 2)
  concepto      String
  orden_id      String?
  usuario_id    String
  created_at    DateTime                @default(now())

  empresa   Empresa      @relation(fields: [empresa_id], references: [id])
  proveedor Proveedor    @relation(fields: [proveedor_id], references: [id])
  orden     OrdenCompra? @relation(fields: [orden_id], references: [id])
  usuario   Usuario      @relation(fields: [usuario_id], references: [id])

  @@index([empresa_id, proveedor_id, created_at])
  @@map("movimientos_cuenta_proveedor")
}

// ─────────────────────────────────────────────────────────────
// FASE 7 — RECURSOS HUMANOS
// Empleados + Áreas (catálogo) + Asistencia + Órdenes de Producción.
// Áreas definen tipo de pago (POR_HORA / POR_PIEZA) y las sanciones.
// Un empleado puede trabajar en distintas áreas cada día.
// ─────────────────────────────────────────────────────────────

enum TipoPago {
  POR_HORA
  POR_PIEZA
}

enum EstatusAsistencia {
  PRESENTE
  AUSENTE
  TARDANZA
  PERMISO
  VACACIONES
}

enum EstatusProduccion {
  ABIERTA
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

// Catálogo de áreas de trabajo por empresa.
// Solo define el nombre y el tipo de pago. Las sanciones se configuran por empleado.
model Area {
  id         String   @id @default(cuid())
  empresa_id String
  nombre     String
  tipo_pago  TipoPago @default(POR_HORA)
  activa     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa   Empresa              @relation(fields: [empresa_id], references: [id])
  empleados Empleado[]
  registros RegistroAsistencia[]

  @@unique([empresa_id, nombre])
  @@index([empresa_id, activa])
  @@map("areas")
}

model Empleado {
  id             String   @id @default(cuid())
  empresa_id     String
  usuario_id     String?  @unique
  nombre         String
  apellidos      String
  puesto         String
  area_id        String?
  salario_diario Decimal  @db.Decimal(12, 2)
  telefono       String?
  fecha_ingreso  DateTime @db.Date
  activo         Boolean  @default(true)
  // Sanciones propias del empleado (el admin define el monto para cada quien)
  descuento_por_30min  Decimal? @db.Decimal(10, 2)  // aplica en áreas POR_HORA
  minimo_piezas_semana Int?                          // aplica en áreas POR_PIEZA
  sancion_por_pieza    Decimal? @db.Decimal(10, 2)  // aplica en áreas POR_PIEZA
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  empresa     Empresa              @relation(fields: [empresa_id], references: [id])
  area        Area?                @relation(fields: [area_id], references: [id])
  usuario     Usuario?             @relation(fields: [usuario_id], references: [id])
  asistencias RegistroAsistencia[]

  @@index([empresa_id, activo])
  @@map("empleados")
}

model RegistroAsistencia {
  id                String            @id @default(cuid())
  empresa_id        String
  empleado_id       String
  area_id           String?           // área donde trabajó ese día (puede diferir de la default)
  fecha             DateTime          @db.Date
  hora_entrada      DateTime?
  hora_salida       DateTime?
  estatus           EstatusAsistencia @default(PRESENTE)
  // Para POR_HORA: minutos tarde para calcular sanción
  minutos_tarde     Int?
  // Para POR_PIEZA: piezas realizadas ese día
  piezas_realizadas Int?
  // Sanción calculada automáticamente al registrar
  sancion_monto     Decimal?          @db.Decimal(10, 2)
  sancion_concepto  String?
  observaciones     String?
  usuario_id        String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  empresa  Empresa   @relation(fields: [empresa_id], references: [id])
  empleado Empleado  @relation(fields: [empleado_id], references: [id])
  area     Area?     @relation(fields: [area_id], references: [id])
  usuario  Usuario   @relation(fields: [usuario_id], references: [id])

  @@unique([empleado_id, fecha])
  @@index([empresa_id, fecha])
  @@map("registros_asistencia")
}

model OrdenProduccion {
  id                 String            @id @default(cuid())
  folio              Int
  empresa_id         String
  articulo_id        String
  existencia_num     Int               @default(1)
  cantidad_objetivo  Decimal           @db.Decimal(12, 3)
  cantidad_producida Decimal           @default(0) @db.Decimal(12, 3)
  estatus            EstatusProduccion @default(ABIERTA)
  fecha_inicio       DateTime          @db.Date
  fecha_cierre       DateTime?
  observaciones      String?
  usuario_id         String
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  empresa  Empresa  @relation(fields: [empresa_id], references: [id])
  articulo Articulo @relation(fields: [articulo_id], references: [id])
  usuario  Usuario  @relation(fields: [usuario_id], references: [id])

  @@unique([empresa_id, folio])
  @@index([empresa_id, estatus, created_at])
  @@map("ordenes_produccion")
}

// ─────────────────────────────────────────────────────────────
// FASE 8 — EDICIÓN CON APROBACIÓN Y EVIDENCIAS
// ─────────────────────────────────────────────────────────────

enum EstatusSolicitudEdicion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoEvidencia {
  TICKET_ORIGINAL
  COMPROBANTE_PAGO
  IMAGEN
  TICKET_REEDITADO
}

// Solicitud para reabrir una nota pagada. Admin aprueba/rechaza.
// Al aprobar se revierte inventario, pagos y saldo automáticamente.
model SolicitudEdicionNota {
  id               String                  @id @default(cuid())
  nota_id          String
  empresa_id       String
  solicitante_id   String
  motivo           String
  estatus          EstatusSolicitudEdicion @default(PENDIENTE)
  aprobado_por_id  String?
  comentario_admin String?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt

  nota         NotaVenta @relation(fields: [nota_id], references: [id])
  empresa      Empresa   @relation(fields: [empresa_id], references: [id])
  solicitante  Usuario   @relation("SolicitudSolicitante", fields: [solicitante_id], references: [id])
  aprobado_por Usuario?  @relation("SolicitudAprobador",  fields: [aprobado_por_id],  references: [id])

  @@index([empresa_id, estatus, created_at])
  @@map("solicitudes_edicion_nota")
}

// Evidencias adjuntas a una nota: ticket original antes de edición,
// comprobantes de pago (tarjeta, transferencia), imágenes, etc.
model EvidenciaNota {
  id            String        @id @default(cuid())
  nota_id       String
  empresa_id    String
  tipo          TipoEvidencia
  descripcion   String?
  archivo_url   String?
  data_json     Json?
  subido_por_id String
  created_at    DateTime      @default(now())

  nota       NotaVenta @relation(fields: [nota_id], references: [id])
  empresa    Empresa   @relation(fields: [empresa_id], references: [id])
  subido_por Usuario   @relation(fields: [subido_por_id], references: [id])

  @@index([nota_id])
  @@map("evidencias_nota")
}

// ─────────────────────────────────────────────────────────────
// LEGACY — Histórico MetalAlpha (solo lectura, no se modifica)
// ─────────────────────────────────────────────────────────────

model LegacyVenta {
  id             String   @id @default(cuid())
  empresa_id     String
  legacy_id      Int
  sucursal       String
  cliente_nombre String?
  nota           String?
  incidencia     String?
  recibido       Decimal? @db.Decimal(12, 2)
  cambio         Decimal? @db.Decimal(12, 2)
  restan         Decimal? @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  estatus        String
  tipo_pago      String
  fecha_hora     DateTime
  created_at     DateTime @default(now())

  empresa Empresa            @relation(fields: [empresa_id], references: [id])
  lineas  LegacyVentaLinea[]

  @@unique([empresa_id, sucursal, legacy_id])
  @@index([empresa_id, fecha_hora])
  @@map("legacy_ventas")
}

model LegacyVentaLinea {
  id            String  @id @default(cuid())
  venta_id      String
  descripcion_1 String?
  descripcion_2 String?
  descripcion_3 String?
  color         String?
  material      String?
  cantidad      Decimal @db.Decimal(12, 3)
  precio_neto   Decimal @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  venta LegacyVenta @relation(fields: [venta_id], references: [id], onDelete: Cascade)

  @@map("legacy_venta_lineas")
}
